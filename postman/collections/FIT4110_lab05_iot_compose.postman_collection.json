{
  "info": {
    "_postman_id": "fit4110-lab05-collection",
    "name": "FIT4110 Lab05 – IoT Compose Stack",
    "description": "Postman collection for end-to-end testing of the Lab 05 Docker Compose stack.\nTests: /health, POST /readings, GET /readings/latest, GET /readings/{id}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "fit4110"
  },
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Body has status ok', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "Create Reading – temperature",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('accepted is true', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.accepted).to.be.true;",
              "    pm.collectionVariables.set('lastReadingId', json.reading_id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-14T08:00:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        }
      },
      "response": []
    },
    {
      "name": "Create Reading – humidity",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('accepted is true', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.accepted).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A02\",\n  \"metric\": \"humidity\",\n  \"value\": 65.0,\n  \"unit\": \"percent\",\n  \"timestamp\": \"2026-06-14T08:01:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        }
      },
      "response": []
    },
    {
      "name": "Create Reading – high temperature (warning)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('X-Warning header present for high temperature', function () {",
              "    pm.expect(pm.response.headers.get('X-Warning')).to.eql('high-temperature');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 75.0,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-14T08:02:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        }
      },
      "response": []
