    {
      "name": "Create Reading – 422 invalid value",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 422', function () {",
              "    pm.response.to.have.status(422);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
