        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 25.0,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-14T08:03:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
