            "value": "Bearer {{authToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 999,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-06-14T08:04:00+07:00\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        }
      },
      "response": []
    },
    {
      "name": "Get Latest Readings",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has items array', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('items');",
              "    pm.expect(json.items).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/readings/latest?limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["readings", "latest"],
          "query": [
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Reading by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('reading_id matches', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.reading_id).to.eql(pm.collectionVariables.get('lastReadingId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/readings/{{lastReadingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["readings", "{{lastReadingId}}"]
        }
      },
      "response": []
    },
    {
      "name": "Get Reading – 404 not found",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/readings/R-NONEXISTENT-0000",
          "host": ["{{baseUrl}}"],
          "path": ["readings", "R-NONEXISTENT-0000"]
        }
      },
      "response": []
    }
  ],
  "variable": [
